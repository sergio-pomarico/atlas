{
  "name": "@atlas/api",
  "version": "1.0.0",
  "main": "dist/app.js",
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsc --project tsconfig.json && tsc-alias",
    "dev": "NODE_ENV=dev tsx watch --no-warnings -r tsconfig-paths/register src/app.ts",
    "start": "NODE_ENV=prod node ./dist/app.js",
    "db:migrate": "tsx -r tsconfig-paths/register src/scripts/migrate.ts migrate dev",
    "db:migrate:deploy": "NODE_ENV=prod tsx -r tsconfig-paths/ripts/migrate.ts migrate deploy",
    "db:migrate:status": "tsx scripts/migrate.ts migrate status",
    "db:push": "tsx scripts/migrate.ts db push",
    "db:studio": "tsx scripts/migrate.ts studio",
    "test": "NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --passWithNoTests"
  },
  "type": "module",
  "author": "Sergio Pomárico <sergiodavid21@gmail.com>",
  "license": "GPL-3.0-only",
  "packageManager": "pnpm@10.8.1",
  "dependencies": {
    "@atlas/entities": "workspace:*",
    "@atlas/schemas": "workspace:*",
    "@atlas/ts-config": "workspace:*",
    "@infisical/sdk": "^4.0.6",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "argon2": "^0.44.0",
    "express": "^5.2.1",
    "inversify": "^7.11.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.18.0",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.0",
    "@types/pg": "^8.16.0",
    "jest": "^30.3.0",
    "prisma": "^7.4.0",
    "ts-jest": "^29.4.6",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
